---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllFAQs } from '../../utils/faq';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

// 在服务端获取所有问答数据
const allFAQs = getAllFAQs(lang, t('surprise.default_tag'));

// 收集所有去重后的标签，并拼装上“全部”
const uniqueTags = [...new Set(allFAQs.map(item => item.tag).filter(Boolean))];
const tags = [t('flashcard.tag_all'), ...uniqueTags];
---

<BaseLayout 
  title={`${t('flashcard.title')} | ADHD OS Blog`} 
  description={t('flashcard.subtitle')}
  lang={lang}
>
  <div class="flashcards-page-wrapper w-full max-w-4xl mx-auto min-h-[60vh] flex flex-col justify-center py-6 md:py-12">
    
    <!-- 极简 Slogan 标语 (专注模式下隐藏，高雅的字间距) -->
    <div class="focus-hide text-center mb-6 text-xs md:text-sm font-bold uppercase tracking-[0.2em] text-zinc-400 select-none">
      {t('flashcard.slogan')}
    </div>

    <!-- Tag 过滤器（专注模式下隐藏，极简文本导航设计） -->
    <nav class="focus-hide flex flex-wrap justify-center gap-x-6 gap-y-2 mb-8 md:mb-10 text-xs md:text-sm font-bold" aria-label="Tag Filter">
      {tags.map((tag, idx) => (
        <button
          type="button"
          class={`tag-filter-btn pb-1 border-b-2 transition-all cursor-pointer select-none ${
            idx === 0 
              ? 'text-zinc-900 border-zinc-900' 
              : 'text-zinc-400 border-transparent hover:text-zinc-700'
          }`}
          data-tag={idx === 0 ? 'all' : tag}
        >
          {tag}
        </button>
      ))}
    </nav>

    <!-- 闪卡主容器 (页面更宽裕：升级为 max-w-3xl) -->
    <main class="flashcards-main-container w-full max-w-3xl mx-auto flex-grow flex flex-col justify-center">

      <!-- 闪卡主体（玻璃态卡片） -->
      <article 
        id="main-flashcard" 
        class="lens-card relative w-full min-h-[380px] p-6 sm:p-8 md:p-10 flex flex-col justify-between overflow-hidden bg-white/70 backdrop-blur-xl border border-black/5 rounded-[2.5rem] shadow-sm select-none"
        data-faqs={JSON.stringify(allFAQs)}
        data-tag-all-label={t('flashcard.tag_all')}
      >
        <!-- Card header metadata -->
        <header class="flex items-center justify-between min-h-[32px] mb-2">
          <!-- Source link -->
          <div class="flex items-center space-x-1 text-[10px] md:text-xs font-bold text-zinc-400 uppercase tracking-wider max-w-[70%]">
            <span class="shrink-0">{t('surprise.from_article')}:</span>
            <a 
              id="card-article-link" 
              href="#" 
              class="font-extrabold text-zinc-800 hover:text-violet-600 transition-colors line-clamp-1 normal-case tracking-normal"
            >
              Loading...
            </a>
          </div>

          <!-- Tag label -->
          <span 
            id="card-tag" 
            class="accent-pill inline-block text-[10px] md:text-xs font-bold px-3 py-1 bg-violet-100 text-violet-700 rounded-full"
          >
            Loading...
          </span>
        </header>

        <!-- Content Area -->
        <section 
          id="card-content-area" 
          class="flex-grow flex flex-col justify-center py-6 md:py-8 transition-opacity duration-150 ease-in-out"
        >
          <!-- Question -->
          <h2 
            id="card-question" 
            class="text-lg sm:text-xl md:text-2xl font-black text-zinc-900 leading-snug tracking-tight text-center md:text-left"
          >
            Loading...
          </h2>
          <!-- Answer -->
          <p 
            id="card-answer" 
            class="text-sm sm:text-base md:text-lg text-zinc-600 leading-relaxed font-medium mt-4 text-center md:text-left"
          >
            Loading...
          </p>
        </section>

        <!-- Card bottom progress bar -->
        <footer class="flex items-center justify-between pt-2 text-xs font-bold text-zinc-400 tracking-wider">
          <span id="card-progress">
            0 / 0
          </span>
        </footer>
      </article>

      <!-- Controls -->
      <section 
        id="flashcard-controls" 
        class="flex items-center justify-center gap-12 mt-6 md:mt-8 w-full max-w-xs mx-auto"
        aria-label="Flashcard Controls"
      >
        <button 
          id="prev-card-btn" 
          type="button"
          aria-label="Previous Flashcard"
          class="text-zinc-400 hover:text-zinc-800 text-2xl font-bold p-3 transition-colors cursor-pointer select-none"
        >
          ←
        </button>

        <button 
          id="next-card-btn" 
          type="button"
          aria-label="Next Flashcard"
          class="text-zinc-400 hover:text-zinc-800 text-2xl font-bold p-3 transition-colors cursor-pointer select-none"
        >
          →
        </button>
      </section>

      <!-- Focus Mode Link -->
      <div class="focus-hide flex justify-center items-center gap-4 mt-6 text-[10px] md:text-xs text-zinc-400 font-bold select-none">
        <button 
          id="enter-focus-btn" 
          type="button" 
          class="hover:text-zinc-800 transition-colors cursor-pointer border-0 bg-transparent p-0 font-bold"
        >
          {t('flashcard.focus_mode')}
        </button>
      </div>

      <!-- Exit Focus Link -->
      <div class="focus-show flex justify-center items-center mt-6 text-[10px] md:text-xs text-zinc-400 font-bold select-none">
        <button 
          id="exit-focus-btn" 
          type="button" 
          class="hover:text-zinc-800 transition-colors cursor-pointer border-0 bg-transparent p-0 font-bold"
        >
          {t('flashcard.exit_focus')} (ESC)
        </button>
      </div>

      <!-- Keyboard tip -->
      <footer class="focus-hide text-center mt-6 px-4">
        <p class="text-[10px] text-zinc-400 font-medium leading-relaxed max-w-md mx-auto">
          {t('flashcard.keyboard_tip')}
        </p>
      </footer>

      <!-- Q&A Bank Container -->
      <div 
        id="qa-bank-container" 
        class="focus-hide w-full max-w-3xl mx-auto mt-12" 
        data-from-label={t('surprise.from_article')}
        data-empty-label={t('flashcard.empty')}
        data-show-bank-label={t('flashcard.show_bank')}
      ></div>

      <!-- Load More Hint Tip -->
      <div 
        id="bank-load-more-tip" 
        class="focus-hide flex flex-col items-center justify-center py-8 text-zinc-400 font-bold select-none text-[10px] md:text-xs tracking-widest gap-2"
      >
        <!-- Bouncing Arrow -->
        <span id="load-more-icon" class="animate-bounce text-sm">↓</span>
        
        <!-- Lemniscate Bloom Math Loader (Initially w-12 h-12 and hidden) -->
        <div id="loader-canvas-wrapper" class="hidden w-12 h-12 text-violet-500">
          <svg viewBox="0 0 100 100" fill="none" class="w-full h-full overflow-visible">
            <g id="loader-group">
              <path id="loader-path" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" opacity="0.1"></path>
            </g>
          </svg>
        </div>

        <span>Scroll down to load more</span>
      </div>

      <!-- Sentinel element for scroll detection (高度缩减为 h-8，底部间距 mb-6，避免底部露出大片空白) -->
      <div 
        id="bank-sentinel" 
        class="focus-hide w-full h-8 pointer-events-none mb-6"
      ></div>

    </main>
  </div>
</BaseLayout>

<style>
  /* Focus mode styles */
  :global(body.focus-active) {
    :global(header) {
      opacity: 0 !important;
      pointer-events: none !important;
      transform: translateY(-100%);
      transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
    }
    :global(footer) {
      opacity: 0 !important;
      pointer-events: none !important;
      transform: translateY(100%);
      transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
    }
    :global(.blob) {
      opacity: 0 !important;
      transition: opacity 0.4s ease !important;
    }
    :global(main.flex-grow) {
      padding-top: 4rem !important;
      transition: padding-top 0.4s ease;
    }
  }

  .focus-hide {
    transition: opacity 0.3s ease, transform 0.3s ease;
    will-change: opacity, transform;
  }
  :global(body.focus-active) .focus-hide {
    opacity: 0 !important;
    pointer-events: none !important;
    transform: translateY(-10px);
  }

  .flashcards-main-container {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  #card-content-area {
    will-change: opacity;
  }

  .focus-show {
    display: none;
  }
  :global(body.focus-active) .focus-show {
    display: flex !important;
  }
</style>

<script>
  function setupFlashcards() {
    // 1. Cleanup previous listeners
    const oldCleanup = (window as any).__flashcardCleanup;
    if (oldCleanup) {
      try {
        oldCleanup();
      } catch (e) {
        console.error('Failed to run flashcard cleanup:', e);
      }
      (window as any).__flashcardCleanup = null;
    }

    const card = document.getElementById('main-flashcard');
    const questionEl = document.getElementById('card-question');
    const answerEl = document.getElementById('card-answer');
    const tagEl = document.getElementById('card-tag');
    const articleLinkEl = document.getElementById('card-article-link') as HTMLAnchorElement;
    const progressEl = document.getElementById('card-progress');
    
    const prevBtn = document.getElementById('prev-card-btn');
    const nextBtn = document.getElementById('next-card-btn');
    const enterFocusBtn = document.getElementById('enter-focus-btn');
    const exitFocusBtn = document.getElementById('exit-focus-btn');
    const bankContainer = document.getElementById('qa-bank-container');
    const loadMoreTip = document.getElementById('bank-load-more-tip');
    const loadMoreIcon = document.getElementById('load-more-icon');
    const loaderWrapper = document.getElementById('loader-canvas-wrapper');
    const loaderGroup = document.getElementById('loader-group');
    const loaderPath = document.getElementById('loader-path');
    const sentinel = document.getElementById('bank-sentinel');
    const contentArea = document.getElementById('card-content-area');
    const filterButtons = document.querySelectorAll('.tag-filter-btn');

    if (
      !card || !questionEl || !answerEl || !tagEl || !articleLinkEl || 
      !progressEl || !prevBtn || !nextBtn || !enterFocusBtn || 
      !exitFocusBtn || !bankContainer || !contentArea
    ) return;

    // Load initial data
    const allFAQs = JSON.parse(card.getAttribute('data-faqs') || '[]');
    const tagAllLabel = card.getAttribute('data-tag-all-label') || 'All';
    let filteredFAQs = [...allFAQs];
    
    const ITEMS_PER_PAGE = 7;
    let visibleCount = ITEMS_PER_PAGE;
    let currentIndex = 0;
    let isTransitioning = false;
    let isPageLoading = false;
    let observer: IntersectionObserver | null = null;
    let animFrameId: number;

    const txtFrom = bankContainer.getAttribute('data-from-label') || 'From Article';
    const txtEmpty = bankContainer.getAttribute('data-empty-label') || 'No Q&As';
    const txtShowBank = bankContainer.getAttribute('data-show-bank-label') || 'Q&A Bank';

    // Lemniscate Bloom math animation implementation
    if (loaderGroup && loaderPath) {
      const loaderConfig = {
        particleCount: 70,
        trailSpan: 0.4,
        durationMs: 5600,
        pulseDurationMs: 5000,
        strokeWidth: 4.8,
        lemniscateA: 20,
        lemniscateBoost: 7,
        point(progress: number, detailScale: number, conf: any) {
          const t = progress * Math.PI * 2;
          const scale = conf.lemniscateA + detailScale * conf.lemniscateBoost;
          const denom = 1 + Math.sin(t) ** 2;
          return {
            x: 50 + (scale * Math.cos(t)) / denom,
            y: 50 + (scale * Math.sin(t) * Math.cos(t)) / denom,
          };
        }
      };

      loaderPath.setAttribute('stroke-width', String(loaderConfig.strokeWidth));

      // Inject 70 particles dynamically
      const loaderParticles = Array.from({ length: loaderConfig.particleCount }, () => {
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('fill', 'currentColor');
        loaderGroup.appendChild(circle);
        return circle;
      });

      function getDetailScale(time: number) {
        const pulseProgress = (time % loaderConfig.pulseDurationMs) / loaderConfig.pulseDurationMs;
        const pulseAngle = pulseProgress * Math.PI * 2;
        return 0.52 + ((Math.sin(pulseAngle + 0.55) + 1) / 2) * 0.48;
      }

      function buildPath(detailScale: number, steps = 180) {
        return Array.from({ length: steps + 1 }, (_, index) => {
          const point = loaderConfig.point(index / steps, detailScale, loaderConfig);
          return `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`;
        }).join(' ');
      }

      function getParticle(index: number, progress: number, detailScale: number) {
        const tailOffset = index / (loaderConfig.particleCount - 1);
        const rawProgress = progress - tailOffset * loaderConfig.trailSpan;
        const normalized = ((rawProgress % 1) + 1) % 1;
        const point = loaderConfig.point(normalized, detailScale, loaderConfig);
        const fade = Math.pow(1 - tailOffset, 0.56);
        return {
          x: point.x,
          y: point.y,
          radius: 0.8 + fade * 2.2,
          opacity: 0.04 + fade * 0.96,
        };
      }

      const startedAt = performance.now();

      function animate(now: number) {
        const time = now - startedAt;
        const progress = (time % loaderConfig.durationMs) / loaderConfig.durationMs;
        const detailScale = getDetailScale(time);
        
        loaderPath!.setAttribute('d', buildPath(detailScale));
        loaderParticles.forEach((node, index) => {
          const particle = getParticle(index, progress, detailScale);
          node.setAttribute('cx', particle.x.toFixed(2));
          node.setAttribute('cy', particle.y.toFixed(2));
          node.setAttribute('r', particle.radius.toFixed(2));
          node.setAttribute('opacity', particle.opacity.toFixed(3));
        });

        animFrameId = requestAnimationFrame(animate);
      }

      animFrameId = requestAnimationFrame(animate);
    }

    // Scroll trigger setup (rootMargin下压20px确保下滑边缘准确，1500ms延时提供充足视觉缓冲)
    function setupObserver() {
      if (observer) {
        observer.disconnect();
      }

      if (!sentinel) return;

      observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isPageLoading) {
          if (visibleCount < filteredFAQs.length) {
            isPageLoading = true;
            
            // Switch to Lemniscate Bloom loading animation on trigger
            if (loadMoreIcon && loaderWrapper) {
              loadMoreIcon.classList.add('hidden');
              loaderWrapper.classList.remove('hidden');
            }
            const tipTextSpan = loadMoreTip?.querySelector('span:last-child');
            if (tipTextSpan) {
              tipTextSpan.textContent = 'Loading more...';
            }

            setTimeout(() => {
              visibleCount += ITEMS_PER_PAGE;
              isPageLoading = false;
              renderBank();
            }, 1500); // 增加至 1500ms
          }
        }
      }, { 
        rootMargin: '0px 0px -20px 0px', // 下压偏移调整为 20px
        threshold: 0.1 
      });

      observer.observe(sentinel);
    }

    // Render Bank
    function renderBank() {
      if (filteredFAQs.length === 0) {
        bankContainer!.innerHTML = `<p class="text-center text-zinc-400 py-8">${txtEmpty}</p>`;
        if (sentinel) sentinel.style.display = 'none';
        if (loadMoreTip) loadMoreTip.style.display = 'none';
        return;
      }

      const visibleFAQs = filteredFAQs.slice(0, visibleCount);

      const listHtml = visibleFAQs.map((faq, index) => {
        return `
          <div class="qa-bank-item p-6 md:p-8 transition-all flex flex-col gap-2 rounded-[2rem] border bg-white/40 border-black/5 shadow-sm hover:bg-white/60">
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-sm md:text-base font-bold text-zinc-900 leading-snug">
                <span class="text-violet-600 font-extrabold mr-1.5">Q${index + 1}.</span>${faq.question}
              </h3>
              <span class="text-[10px] md:text-xs font-bold px-2 py-0.5 bg-zinc-100/80 text-zinc-500 rounded-full shrink-0 uppercase tracking-wider">${faq.tag}</span>
            </div>
            <p class="text-xs md:text-sm text-zinc-600 leading-relaxed font-medium">
              <span class="text-zinc-400 font-extrabold mr-1.5">A.</span>${faq.answer}
            </p>
            <div class="text-[10px] md:text-xs font-bold text-zinc-400 mt-2 uppercase tracking-wider">
              ${txtFrom}: <a href="${faq.articleHref}" class="text-zinc-500 hover:text-violet-600 transition-colors underline decoration-dotted">${faq.articleTitle}</a>
            </div>
          </div>
        `;
      }).join('');

      bankContainer!.innerHTML = `
        <div class="flex flex-col gap-4">
          <!-- Bank title -->
          <div class="flex items-center gap-2 mb-2 text-[10px] md:text-xs font-bold text-zinc-400 uppercase tracking-widest pl-2">
            <span class="w-1.5 h-1.5 rounded-full bg-violet-500 animate-pulse"></span>
            ${txtShowBank}
          </div>
          <div class="flex flex-col gap-4">
            ${listHtml}
          </div>
        </div>
      `;

      // Set tip visibility and reset state
      if (sentinel && loadMoreTip) {
        if (visibleCount >= filteredFAQs.length) {
          sentinel.style.display = 'none';
          loadMoreTip.style.display = 'none';
        } else {
          sentinel.style.display = 'block';
          loadMoreTip.style.display = 'flex';
          
          if (loadMoreIcon && loaderWrapper) {
            loadMoreIcon.classList.remove('hidden');
            loaderWrapper.classList.add('hidden');
          }
          const tipTextSpan = loadMoreTip.querySelector('span:last-child');
          if (tipTextSpan) {
            tipTextSpan.textContent = 'Scroll down to load more';
          }
        }
      }

      setupObserver();
    }

    // Render single card content
    function renderCard(fade = true) {
      if (filteredFAQs.length === 0) {
        questionEl!.textContent = 'No flashcards in this category';
        answerEl!.textContent = '';
        articleLinkEl!.textContent = 'Home';
        articleLinkEl!.href = '/en';
        tagEl!.textContent = '-';
        progressEl!.textContent = '0 / 0';
        renderBank();
        return;
      }

      if (currentIndex >= visibleCount) {
        visibleCount = Math.floor(currentIndex / ITEMS_PER_PAGE + 1) * ITEMS_PER_PAGE;
      }

      const faq = filteredFAQs[currentIndex];

      const applyContent = () => {
        questionEl!.textContent = faq.question;
        answerEl!.textContent = faq.answer;
        tagEl!.textContent = faq.tag;
        articleLinkEl!.textContent = faq.articleTitle;
        articleLinkEl!.href = faq.articleHref;
        progressEl!.textContent = `${currentIndex + 1} / ${filteredFAQs.length}`;
        
        renderBank();
      };

      if (fade) {
        isTransitioning = true;
        contentArea!.classList.add('opacity-0');
        setTimeout(() => {
          applyContent();
          contentArea!.classList.remove('opacity-0');
          setTimeout(() => {
            isTransitioning = false;
          }, 150);
        }, 150);
      } else {
        applyContent();
      }
    }

    // Card change handlers
    function changeCard(direction: 'next' | 'prev') {
      if (isTransitioning || filteredFAQs.length <= 1) return;

      if (direction === 'next') {
        currentIndex = (currentIndex + 1) % filteredFAQs.length;
      } else {
        currentIndex = (currentIndex - 1 + filteredFAQs.length) % filteredFAQs.length;
      }
      renderCard(true);
    }

    function setFocusMode(active: boolean) {
      if (active) {
        document.body.classList.add('focus-active');
      } else {
        document.body.classList.remove('focus-active');
      }
    }

    filterButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const selectedTag = target.getAttribute('data-tag');

        filterButtons.forEach(b => {
          b.classList.remove('text-zinc-900', 'border-zinc-900');
          b.classList.add('text-zinc-400', 'border-transparent');
        });
        target.classList.remove('text-zinc-400', 'border-transparent');
        target.classList.add('text-zinc-900', 'border-zinc-900');

        if (selectedTag === 'all') {
          filteredFAQs = [...allFAQs];
        } else {
          filteredFAQs = allFAQs.filter((faq: any) => faq.tag === selectedTag);
        }

        currentIndex = 0;
        visibleCount = ITEMS_PER_PAGE;
        renderCard(true);
      });
    });

    const handlePrev = () => changeCard('prev');
    const handleNext = () => changeCard('next');
    const handleEnterFocus = () => setFocusMode(true);
    const handleExitFocus = () => setFocusMode(false);

    prevBtn.addEventListener('click', handlePrev);
    nextBtn.addEventListener('click', handleNext);
    enterFocusBtn.addEventListener('click', handleEnterFocus);
    exitFocusBtn.addEventListener('click', handleExitFocus);

    const handleKeyDown = (e: KeyboardEvent) => {
      if (document.activeElement?.tagName === 'INPUT' || document.activeElement?.tagName === 'TEXTAREA') {
        return;
      }
      
      switch (e.key) {
        case 'ArrowRight':
          e.preventDefault();
          changeCard('next');
          break;
        case 'ArrowLeft':
          e.preventDefault();
          changeCard('prev');
          break;
        case 'Escape':
          e.preventDefault();
          const isFocused = document.body.classList.contains('focus-active');
          setFocusMode(!isFocused);
          break;
      }
    };

    window.addEventListener('keydown', handleKeyDown);

    setupObserver();
    renderCard(false);

    (window as any).__flashcardCleanup = () => {
      window.removeEventListener('keydown', handleKeyDown);
      prevBtn.removeEventListener('click', handlePrev);
      nextBtn.removeEventListener('click', handleNext);
      enterFocusBtn.removeEventListener('click', handleEnterFocus);
      exitFocusBtn.removeEventListener('click', handleExitFocus);
      if (observer) observer.disconnect();
      if (animFrameId) cancelAnimationFrame(animFrameId);
      document.body.classList.remove('focus-active');
    };
  }

  setupFlashcards();
  document.addEventListener('astro:page-load', setupFlashcards);
</script>
