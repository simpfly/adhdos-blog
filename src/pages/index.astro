---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SurpriseMe from '../components/SurpriseMe.astro';
import { useTranslations } from '../i18n/utils';
import { defaultLang } from '../i18n/ui';
const lang = defaultLang;
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="ADHD OS Blog | 探索神经多样性" description="享受分心，自然专注。写给神经多样性大脑的自救指南——ADHD、ASD 的执行功能、时间盲、情绪调节与科学糊弄哲学。">
  <!-- Hero & Q&A Grid Layout -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center mb-16 md:mb-24 mt-8 md:mt-16">
    <!-- Left: Slogan (Hero Section) -->
    <div class="lg:col-span-6 text-center lg:text-left">
      <div class="flex items-start gap-4 justify-center lg:justify-start">
        <img src="https://adhdos.app/assets/icon_ADHDOS.png" alt="ADHD OS Logo" class="w-14 h-14 rounded-2xl shadow-sm border border-black/5 flex-shrink-0 mt-1.5" />
        <div class="space-y-2 text-left">
          <h1 class="text-3xl md:text-4xl font-black tracking-tight text-black leading-tight">
            ADHDOS<span class="text-violet-600 font-medium">：Mind→Move</span>
          </h1>
          <p class="text-lg md:text-xl text-zinc-500 font-medium leading-relaxed">
            享受分心，自然专注。
          </p>
        </div>
      </div>
    </div>

    <!-- Right: Q&A Card -->
    <div class="lg:col-span-6 w-full flex lg:justify-end">
      <SurpriseMe lang={lang} />
    </div>
  </div>

  <!-- Articles List -->
  <div class="mb-12 text-center md:text-left">
    <h2 class="text-3xl font-black text-black tracking-tight">{t('home.all_articles')}</h2>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </div>
</BaseLayout>
