---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<BaseLayout title="ADHD OS Blog | 探索神经多样性" description="关于神经多样性、前端开发、生产力工具的思考与分享。">
  <!-- Hero Section -->
  <div class="text-center mb-24 md:mb-32 space-y-6 mt-8 md:mt-16 relative">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-black/5 border border-black/5 text-black text-xs md:text-sm font-bold backdrop-blur-md mb-4">
      <span class="w-2 h-2 rounded-full bg-violet-500 animate-pulse"></span>
      <span>最新文章更新</span>
    </div>
    
    <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-[#2D2B35] leading-[1.1]">
      <span class="italic">Mind</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right inline-block mx-2 md:mx-4 text-zinc-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      <span class="italic">Move</span>
      <br/>
      探索<span class="text-violet-600">神经多样性</span>
    </h1>
    
    <p class="text-lg md:text-xl text-zinc-500 max-w-2xl mx-auto font-medium mt-6">
      享受分心，自然专注。在这里记录构建 ADHD OS 的过程，分享关于专注力、系统设计与个人成长的故事。
    </p>
  </div>

  <!-- Articles List -->
  <div class="mb-12 text-center md:text-left">
    <h2 class="text-3xl font-black text-black tracking-tight">所有文章</h2>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </div>
</BaseLayout>
