---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Agent 接入中心 - ADHD OS';
const description = '将 ADHD OS 知识库一键接入您的 AI 助手，无需 API Key，匿名只读。';

const openApiSchema = JSON.stringify({
  "openapi": "3.1.0",
  "info": { "title": "ADHD OS Blog Knowledge Base API", "version": "1.0.0" },
  "servers": [{ "url": "https://blog.adhdos.app" }],
  "paths": {
    "/api/knowledge.json": {
      "get": {
        "operationId": "getKnowledgeBase",
        "summary": "Retrieve the full blog posts knowledge base",
        "responses": { "200": { "description": "JSON array of articles with metadata and markdown content." } }
      }
    }
  }
}, null, 2);

const agentPrompt = `请检查并安装 ADHD OS 知识库 Skill。

规则文件：https://blog.adhdos.app/adhdos-skill/SKILL.md
说明文件：https://blog.adhdos.app/adhdos-skill/README.md

要求：
1. 先读取并检查这两个文件，确认仅访问公开只读接口；
2. 告诉我你准备写入的用户级 skills 目录和文件名，不要使用 sudo，不要覆盖其它无关 Skill；
3. 确认后完成写入，完成技能安装；
4. 告诉我是否需要重启或开启新会话，并提供一个验证问题。`;

const updatePrompt = `请更新当前已安装的 ADHD OS Skill。

新版规则文件：https://blog.adhdos.app/adhdos-skill/SKILL.md
新版说明文件：https://blog.adhdos.app/adhdos-skill/README.md

步骤：
1. 先找到你当前会话实际加载的 adhdos-kb/SKILL.md 路径；
2. 确认旧版本内容与目标写入路径；
3. 下载新文件并覆盖写入同一目录，不要写到其它 Agent 目录。`;
---

<BaseLayout title={title} description={description} lang="zh">
  <!-- 隐藏 SVG 定义区：copy 和 check 图标各定义一次，全页复用 -->
  <svg xmlns="http://www.w3.org/2000/svg" class="hidden" aria-hidden="true">
    <symbol id="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
      <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
    </symbol>
    <symbol id="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 6 9 17l-5-5"/>
    </symbol>
  </svg>

  <div class="max-w-3xl mx-auto pb-24 px-4">
    <!-- 顶栏 -->
    <div class="border-b border-black/5 pb-6 mb-10">
      <div class="text-xs font-bold text-violet-dark uppercase tracking-wider mb-1">Agent Skills & API</div>
      <h1 class="text-3xl font-extrabold tracking-tight text-zinc-900">Agent 接入中心</h1>
    </div>

    <!-- 简要说明 -->
    <p class="text-zinc-600 text-base mb-10 leading-relaxed">
      您可以将本站关于多动症 (ADHD) 与自闭特质 (ASD) 的科学自救指南无缝接进您的 AI 助手 (如 Claude, Gemini, Codex, Hermes)。匿名只读，无需配置 API Key。
    </p>

    <!-- 接入前后对比演示 -->
    <div class="mb-12">
      <h2 class="text-lg font-bold text-zinc-900 mb-6 text-center">接入 Agent 知识库的效果对比</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <!-- 接入前 -->
        <div class="border border-zinc-200 bg-zinc-50/50 p-6 rounded-2xl opacity-75">
          <div class="text-xs font-bold text-zinc-500 uppercase tracking-wider mb-3">接入前 (普通大模型回答)</div>
          <div class="text-xs text-zinc-400 mb-4 pb-2 border-b border-zinc-200">
            问：ADHD 遇到任务瘫痪（Task Paralysis）怎么自救？
          </div>
          <div class="text-xs text-zinc-600 space-y-2 leading-relaxed">
            <p class="font-bold text-zinc-800">AI 助手：</p>
            <p>面对任务瘫痪，不可否认这确实是一个巨大的挑战。在这充满不确定性与压力的现代社会里，我们建议您：</p>
            <p>
              1. 制定极其详尽的长期规划，细化到每小时；<br/>
              2. 排除所有干扰，强迫自己立刻坐下来开始工作；<br/>
              3. 保持积极向上的心态，相信自己能完成。<br/>
              总之，拖延是完全可以通过坚强的意志力克服的。
            </p>
            <p class="text-[10px] text-zinc-400 italic">(缺陷：字块密集、充满空泛的 AI 套话、缺乏多动症实操针对性、带有意志力施压)</p>
          </div>
        </div>

        <!-- 接入后 -->
        <div class="border-2 border-violet bg-white p-6 rounded-2xl shadow-sm">
          <div class="text-xs font-bold text-violet-dark uppercase tracking-wider mb-3">接入后 (注入知识库后的 Agent)</div>
          <div class="text-xs text-zinc-400 mb-4 pb-2 border-b border-zinc-200">
            问：ADHD 遇到任务瘫痪（Task Paralysis）怎么自救？
          </div>
          <div class="text-xs text-zinc-600 space-y-3 leading-relaxed">
            <p class="font-bold text-zinc-800">AI 助手：</p>
            <p>遇到任务瘫痪时，请不要尝试强迫自己使用意志力，建议通过以下步骤进行<strong>物理破局</strong>：</p>
            <ul class="list-disc pl-4 space-y-1.5">
              <li><strong>降低启动门槛</strong>：不要求写完文档，只要求<strong>打开软件写 1 个字</strong>，打破等待模式。</li>
              <li><strong>身体双倍（Body Doubling）</strong>：寻找同伴或在直播间工作，借用外部场域提供多巴胺。</li>
              <li><strong>拆解至微小行动</strong>：将大任务拆分为 <strong>3 分钟内即可完成的微行动</strong>，消除对任务体积的恐惧。</li>
            </ul>
            <p class="text-[10px] text-zinc-500 pt-1">来源：[《ADHD 任务瘫痪 SOS 自救指南》](https://blog.adhdos.app/adhd-task-paralysis-sos)</p>
            <p class="text-[10px] text-violet-dark italic">(优势：排白舒适、核心动作加粗以利视觉扫描、提供具体的科学策略、去 AI 腔调、透明溯源)</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 方案一 -->
    <div class="lens-card p-6 md:p-8 mb-8 bg-brand-50/10" style="content-visibility:auto;contain-intrinsic-size:auto 240px">
      <h2 class="text-lg font-bold text-zinc-900 mb-2 flex items-center gap-2">
        <span class="flex h-5 w-5 items-center justify-center rounded-full bg-violet text-white text-[10px] font-bold">1</span>
        方式一：直接发送提示词给 AI
      </h2>
      <p class="text-xs text-zinc-500 mb-4 leading-relaxed">
        如果您使用的 AI 助手拥有管理本地文件的权限，直接复制并发送下方这段提示词给它，AI 会自动拉取规范并完成技能安装。
      </p>
      <div class="group bg-zinc-50 border border-zinc-200 rounded-xl p-4 relative mb-4">
        <p class="text-xs text-zinc-700 font-mono leading-relaxed pr-12 whitespace-pre-line">{agentPrompt}</p>
        <button class="copy-btn absolute top-3 right-3 p-1.5 bg-white hover:bg-zinc-50 text-zinc-500 hover:text-zinc-700 rounded-lg border border-zinc-200 active:scale-95 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer flex items-center justify-center" data-copy={agentPrompt} title="复制提示词">
          <svg width="14" height="14" class="copy-icon"><use href="#icon-copy"/></svg>
          <svg width="14" height="14" class="check-icon hidden"><use href="#icon-check"/></svg>
        </button>
      </div>
      <a href="/adhdos-skill/SKILL.md" target="_blank" class="text-xs font-semibold text-violet-dark hover:underline">查看 SKILL.md 规则定义</a>
    </div>

    <!-- 方案二 -->
    <div class="lens-card p-6 md:p-8 mb-8" style="content-visibility:auto;contain-intrinsic-size:auto 260px">
      <h2 class="text-lg font-bold text-zinc-900 mb-2 flex items-center gap-2">
        <span class="flex h-5 w-5 items-center justify-center rounded-full bg-violet text-white text-[10px] font-bold">2</span>
        方式二：在终端中一键安装
      </h2>
      <p class="text-xs text-zinc-500 mb-4 leading-relaxed">
        如果您在使用本地的 Agent 客户端，请复制下方对应平台的终端命令并执行：
      </p>
      <div class="space-y-4">
        {[
          { label: 'Claude Desktop', target: 'claude' },
          { label: 'Codex Agent',    target: 'codex'  },
          { label: 'Hermes / 其它通用 Agent', target: 'agents' },
        ].map(({ label, target }) => (
          <div>
            <span class="text-[11px] font-bold text-zinc-400 block mb-1">{label}</span>
            <div class="group bg-zinc-50 border border-zinc-200 text-zinc-800 text-xs p-4 rounded-xl font-mono flex items-center justify-between gap-4">
              <span class="overflow-x-auto whitespace-nowrap text-[11px] pr-2">bash &lt;(curl -fsSL https://blog.adhdos.app/install-skill.sh) --target {target}</span>
              <button class="copy-btn shrink-0 p-1.5 bg-white hover:bg-zinc-50 text-zinc-500 hover:text-zinc-700 rounded-lg border border-zinc-200 active:scale-95 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer flex items-center justify-center"
                data-copy={`bash <(curl -fsSL https://blog.adhdos.app/install-skill.sh) --target ${target}`} title="复制命令">
                <svg width="14" height="14" class="copy-icon"><use href="#icon-copy"/></svg>
                <svg width="14" height="14" class="check-icon hidden"><use href="#icon-check"/></svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 方案三 -->
    <div class="lens-card p-6 md:p-8 mb-8" style="content-visibility:auto;contain-intrinsic-size:auto 220px">
      <h2 class="text-lg font-bold text-zinc-900 mb-2 flex items-center gap-2">
        <span class="flex h-5 w-5 items-center justify-center rounded-full bg-violet text-white text-[10px] font-bold">3</span>
        方式三：直接获取数据接口 (API)
      </h2>
      <p class="text-xs text-zinc-500 mb-4 leading-relaxed">
        如果您打算开发自己的检索应用，可以直接点击超链接调用以下接口，或使用右侧按钮进行复制：
      </p>
      <div class="space-y-3">
        {[
          { name: '全站索引地图 (llms.txt)', desc: '列出博客简介、中英文分类和所有文章的大纲及描述', href: '/llms.txt', url: 'https://blog.adhdos.app/llms.txt' },
          { name: '全量 Markdown 打包 (llms-full.txt)', desc: '将全站所有文章的原始 Markdown 全文拼接为一个包，方便直接注入上下文', href: '/llms-full.txt', url: 'https://blog.adhdos.app/llms-full.txt' },
          { name: 'JSON 知识库 API (knowledge.json)', desc: '返回包含文章标题、摘要、中英文标签和 Markdown 原文的强类型 JSON 数组', href: '/api/knowledge.json', url: 'https://blog.adhdos.app/api/knowledge.json' },
        ].map(({ name, desc, href, url }, i) => (
          <div class={`group flex justify-between items-center text-xs ${i < 2 ? 'border-b border-black/5 pb-3' : ''}`}>
            <div class="pr-4">
              <span class="font-bold text-zinc-800 block">{name}</span>
              <span class="text-[11px] text-zinc-400 block mb-1">{desc}</span>
              <a href={href} target="_blank" class="text-[11px] text-violet-dark hover:underline font-mono">{url}</a>
            </div>
            <button class="copy-btn shrink-0 p-1.5 bg-white hover:bg-zinc-50 text-zinc-500 hover:text-zinc-700 rounded-lg border border-zinc-200 active:scale-95 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer flex items-center justify-center"
              data-copy={url} title="复制链接">
              <svg width="14" height="14" class="copy-icon"><use href="#icon-copy"/></svg>
              <svg width="14" height="14" class="check-icon hidden"><use href="#icon-check"/></svg>
            </button>
          </div>
        ))}
      </div>
    </div>

    <!-- 验证 + 更新 -->
    <div class="grid md:grid-cols-2 gap-6 mb-12" style="content-visibility:auto;contain-intrinsic-size:auto 200px">
      <div class="bg-zinc-50 border border-zinc-200 rounded-2xl p-6">
        <h3 class="text-sm font-bold text-zinc-800 mb-2">安装验证方法</h3>
        <p class="text-xs text-zinc-500 leading-relaxed mb-3">
          安装后重启会话，选以下任意一题向 AI 提问。若回答包含加粗重点、层次结构和来源出处，说明接入成功：
        </p>
        <div class="space-y-2">
          {[
            { tag: 'ADHD', q: 'ADHD 拖延症与完美主义之间有什么关系？有什么自救方案吗？' },
            { tag: 'ASD', q: '社交后为什么感觉彻底耗尽电量？怎么快速恢复社交电池？' },
            { tag: '女性 ND', q: '女性 ADHD 为什么容易在生理期前后症状加重？有什么应对策略？' },
          ].map(({ tag, q }) => (
            <div class="group bg-white border border-zinc-200 text-zinc-700 text-xs p-3 rounded-lg font-mono relative pr-10">
              <span class="inline-block text-[10px] font-bold text-violet-dark bg-violet/8 rounded px-1 py-0.5 mb-1">{tag}</span>
              <p class="leading-relaxed">{q}</p>
              <button class="copy-btn absolute top-2.5 right-2 p-1.5 bg-white hover:bg-zinc-50 text-zinc-500 hover:text-zinc-700 rounded-lg border border-zinc-200 active:scale-95 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer flex items-center justify-center"
                data-copy={q} title="复制问题">
                <svg width="14" height="14" class="copy-icon"><use href="#icon-copy"/></svg>
                <svg width="14" height="14" class="check-icon hidden"><use href="#icon-check"/></svg>
              </button>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-zinc-50 border border-zinc-200 rounded-2xl p-6">
        <h3 class="text-sm font-bold text-zinc-800 mb-2">如何覆盖更新 Skill</h3>
        <p class="text-xs text-zinc-500 leading-relaxed mb-3">
          若日后需要更新已安装的知识库技能，复制并发送下方提示词给您的 AI 助手即可：
        </p>
        <div class="group bg-white border border-zinc-200 text-zinc-700 text-xs p-3 rounded-lg font-mono relative pr-12 whitespace-pre-line leading-relaxed">
          <span>{updatePrompt}</span>
          <button class="copy-btn absolute top-2 right-2 p-1.5 bg-white hover:bg-zinc-50 text-zinc-500 hover:text-zinc-700 rounded-lg border border-zinc-200 active:scale-95 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer flex items-center justify-center"
            data-copy={updatePrompt} title="复制更新指令">
            <svg width="14" height="14" class="copy-icon"><use href="#icon-copy"/></svg>
            <svg width="14" height="14" class="check-icon hidden"><use href="#icon-check"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- OpenAPI -->
    <div class="text-center text-xs text-zinc-400">
      接口协议符合 OpenAPI 规范。
      <details class="mt-2 text-left bg-zinc-50 border border-zinc-200 rounded-xl p-4 font-mono text-[10px] cursor-pointer inline-block w-full">
        <summary class="text-zinc-500 hover:text-zinc-700 font-bold">展开查看极简 OpenAPI 架构定义</summary>
        <pre class="mt-2 text-zinc-800 overflow-x-auto bg-zinc-50 border border-zinc-200 p-4 rounded-xl"><code set:text={openApiSchema}></code></pre>
      </details>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const text = btn.dataset.copy;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const copyIcon = btn.querySelector<SVGElement>('.copy-icon');
        const checkIcon = btn.querySelector<SVGElement>('.check-icon');
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        btn.classList.add('bg-violet/10', 'border-violet/30', 'text-violet-dark');
        btn.classList.remove('text-zinc-500', 'border-zinc-200');
        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
          btn.classList.remove('bg-violet/10', 'border-violet/30', 'text-violet-dark');
          btn.classList.add('text-zinc-500', 'border-zinc-200');
        }, 1500);
      } catch {
        // clipboard not available
      }
    });
  });
</script>
