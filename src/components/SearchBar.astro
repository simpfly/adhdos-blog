---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Predefined hot keywords for search recommendations
const recommendedTags = lang === 'zh' 
  ? ['ADHD', 'ASD', '亲密关系', '感官寻求', '执行功能', '习惯建立', '睡眠相位后移', '糊弄哲学']
  : ['ADHD', 'ASD', 'Relationships', 'Sensory', 'Executive Function', 'Habits', 'Sleep', 'Good-enoughism'];
---

<div class="search-container w-full max-w-xl mx-auto mb-10 relative">
  <!-- Search Input Wrapper -->
  <div class="relative w-full">
    <!-- Search Icon -->
    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400 pointer-events-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    </div>

    <!-- Input Box -->
    <input
      type="text"
      id="blog-search"
      placeholder={t('search.placeholder')}
      class="w-full py-3.5 pl-12 pr-12 text-[15px] font-medium text-black bg-zinc-50/80 border border-black/10 rounded-2xl shadow-[0_2px_8px_rgba(0,0,0,0.02)] focus:bg-white focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 focus:outline-none transition-all duration-250 placeholder-zinc-400"
      autocomplete="off"
    />

    <!-- Clear Button -->
    <button
      id="search-clear"
      type="button"
      class="absolute right-4 top-1/2 -translate-y-1/2 p-1 rounded-full text-zinc-400 hover:text-black hover:bg-zinc-100 opacity-0 pointer-events-none scale-90 transition-all duration-200"
      aria-label="Clear search"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

    <!-- Recommendations Dropdown Panel -->
    <div
      id="search-recommendations"
      class="absolute left-0 right-0 top-full mt-2 bg-white/95 backdrop-blur-md border border-black/5 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.08)] p-5 z-20 opacity-0 -translate-y-2 pointer-events-none scale-[0.99] transition-all duration-200"
    >
      <span class="text-[11px] font-bold text-zinc-400 tracking-wider mb-3 block uppercase select-none">
        {t('search.recommended')}
      </span>
      <div class="flex flex-wrap gap-2">
        {recommendedTags.map(tag => (
          <button
            type="button"
            class="recommendation-badge px-3 py-1.5 bg-zinc-50 hover:bg-violet-50/80 text-zinc-600 hover:text-violet-700 border border-black/5 hover:border-violet-200 text-xs font-semibold rounded-xl cursor-pointer transition-all duration-150 active:scale-95"
            data-recommend-tag={tag}
          >
            {tag}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- No Results Placeholder (controlled via JS) -->
  <div id="search-no-results" class="hidden text-center py-16 px-4 border border-dashed border-black/10 rounded-2xl bg-zinc-50/30 mt-8">
    <div class="text-zinc-300 mb-3 flex justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder-search"><path d="M11 20H4a2 2 0 0 1-2-2V5c0-1.1.9-2 2-2h3.93a2 2 0 0 1 1.66.9l.82 1.2a2 2 0 0 0 1.66.9H20a2 2 0 0 1 2 2v2.5"/><circle cx="17" cy="17" r="3"/><path d="m21 21-1.9-1.9"/></svg>
    </div>
    <p class="text-zinc-500 text-sm font-semibold mb-0">
      {t('search.no_results')}
    </p>
  </div>
</div>

<script>
  function setupSearch() {
    const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
    const clearButton = document.getElementById('search-clear') as HTMLButtonElement | null;
    const noResults = document.getElementById('search-no-results') as HTMLDivElement | null;
    const recommendationsPanel = document.getElementById('search-recommendations') as HTMLDivElement | null;
    
    const cards = document.querySelectorAll('[data-post-card]');

    if (!searchInput || !cards.length) return;

    let blurTimeout: number | undefined;

    // Helper functions for recommendations panel
    const showRecommendations = () => {
      if (!recommendationsPanel) return;
      if (searchInput.value.trim() === '') {
        recommendationsPanel.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-2', 'scale-[0.99]');
        recommendationsPanel.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0', 'scale-100');
      }
    };

    const hideRecommendations = () => {
      if (!recommendationsPanel) return;
      recommendationsPanel.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0', 'scale-100');
      recommendationsPanel.classList.add('opacity-0', 'pointer-events-none', '-translate-y-2', 'scale-[0.99]');
    };

    // Input events and search logic
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      const keywords = query.split(/\s+/).filter(k => k.length > 0);
      
      // Control Clear Button visibility
      if (clearButton) {
        if (query.length > 0) {
          clearButton.classList.remove('opacity-0', 'pointer-events-none', 'scale-90');
          clearButton.classList.add('opacity-100', 'pointer-events-auto', 'scale-100');
          // Hide recommendations as user has started typing
          hideRecommendations();
        } else {
          clearButton.classList.remove('opacity-100', 'pointer-events-auto', 'scale-100');
          clearButton.classList.add('opacity-0', 'pointer-events-none', 'scale-90');
          // Show recommendations again when search input is cleared
          showRecommendations();
        }
      }

      let matchCount = 0;

      cards.forEach((card) => {
        const title = card.getAttribute('data-title') || '';
        const description = card.getAttribute('data-description') || '';
        const tags = card.getAttribute('data-tags') || '';

        // If no keywords, it's a match. Otherwise, EVERY keyword must appear in at least one field.
        const isMatch = keywords.length === 0 || keywords.every(keyword => 
          title.includes(keyword) || description.includes(keyword) || tags.includes(keyword)
        );

        if (isMatch) {
          card.classList.remove('hidden');
          matchCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // Toggle No Results Block
      if (noResults) {
        if (matchCount === 0) {
          noResults.classList.remove('hidden');
        } else {
          noResults.classList.add('hidden');
        }
      }
    });

    // Input Focus / Blur Logic
    searchInput.addEventListener('focus', () => {
      if (blurTimeout) clearTimeout(blurTimeout);
      showRecommendations();
    });

    searchInput.addEventListener('blur', () => {
      // Small delay to allow click/mousedown events on recommendation buttons to fire
      blurTimeout = window.setTimeout(() => {
        hideRecommendations();
      }, 200);
    });

    // Clear search event
    if (clearButton) {
      clearButton.addEventListener('click', () => {
        searchInput.value = '';
        searchInput.focus();
        searchInput.dispatchEvent(new Event('input'));
      });
    }

    // Event listener for click redirection (recommendation topics and tag badges)
    const handleGlobalClick = (e: MouseEvent) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;

      // Case 1: Clicked on a recommendation topic button
      if (target.hasAttribute('data-recommend-tag')) {
        e.preventDefault();
        e.stopPropagation();
        if (blurTimeout) clearTimeout(blurTimeout);
        
        const tagValue = target.getAttribute('data-recommend-tag') || '';
        searchInput.value = tagValue;
        searchInput.focus();
        searchInput.dispatchEvent(new Event('input'));
      }

      // Case 2: Clicked on a blog post tag badge
      if (target.hasAttribute('data-search-tag')) {
        e.preventDefault();
        e.stopPropagation();
        
        const tagValue = target.getAttribute('data-search-tag') || '';
        searchInput.value = tagValue;
        searchInput.focus();
        searchInput.dispatchEvent(new Event('input'));
        
        // Soft scroll up to the search input if it's out of viewport
        searchInput.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    document.addEventListener('click', handleGlobalClick);
    
    // Store reference to clean up listener on view swap to avoid duplicates
    (window as any)._currentGlobalClickHandler = handleGlobalClick;
  }

  // Cleanup helper for Astro View Transitions
  document.addEventListener('astro:before-swap', () => {
    if ((window as any)._currentGlobalClickHandler) {
      document.removeEventListener('click', (window as any)._currentGlobalClickHandler);
    }
  });

  // Run on page load
  setupSearch();
  document.addEventListener('astro:after-swap', setupSearch);
</script>
