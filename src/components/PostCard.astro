---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, heroImage } = post.data;

const [lang, ...slugParts] = post.id.split('/');
const slug = slugParts.join('/');
const href = lang === 'zh' ? `/${slug}/` : `/${lang}/${slug}/`;
const locale = lang === 'en' ? 'en-US' : 'zh-CN';
const heroImageAlt = `${title}${lang === 'en' ? ' — cover image' : ' · 封面图'}`;
---
<a href={href} class="lens-card group flex flex-col overflow-hidden min-h-[300px]" data-post-card data-title={title.toLowerCase()} data-description={description.toLowerCase()} data-tags={tags?.join(',').toLowerCase()}>
  {heroImage && (
    <div class="aspect-[16/9] w-full overflow-hidden border-b border-black/5 bg-zinc-50 relative">
      <Image src={heroImage} alt={heroImageAlt} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" />
    </div>
  )}
  <div class="flex-grow p-6 md:p-8 flex flex-col justify-between">
    <div class="flex-grow">
      {!heroImage && (
        <!-- Icon Placeholder -->
        <div class="w-12 h-12 rounded-2xl bg-white flex items-center justify-center mb-6 transition-colors duration-500 group-hover:bg-violet-300 shadow-sm border border-black/5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text text-black"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
        </div>
      )}
      
      <div class="flex flex-wrap gap-2 mb-4">
        {tags?.map(tag => (
          <span class="px-2 py-1 bg-violet-100 text-violet-800 text-[10px] font-bold rounded-full border border-violet-200">
            {tag}
          </span>
        ))}
      </div>
      
      <h3 class="text-2xl font-black mb-3 text-black tracking-tight transition-colors">
        {title}
      </h3>
      
      <p class="text-zinc-500 text-sm leading-relaxed line-clamp-3">
        {description}
      </p>
    </div>
    
    <div class="text-xs text-zinc-400 font-medium mt-6 flex items-center justify-between border-t border-black/5 pt-4">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString(locale, {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      <div class="flex items-center gap-1 text-black opacity-0 group-hover:opacity-100 transition-opacity -translate-x-2 group-hover:translate-x-0 transform duration-300">
        阅读 <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>
    </div>
  </div>
</a>
