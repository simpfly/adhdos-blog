---
interface Props {
  questions: {
    question: string;
    answer: string;
  }[];
}
const { questions } = Astro.props;

const isEn = Astro.url.pathname.startsWith('/en/') || Astro.url.pathname.startsWith('/en');
const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": isEn ? "en-US" : "zh-CN",
  "mainEntityOfPage": Astro.url.href,
  "mainEntity": questions.map(q => ({
    "@type": "Question",
    "name": q.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": q.answer
    }
  }))
};
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

<div class="faq-list space-y-6 mt-6">
  {questions.map((q) => (
    <div class="faq-item border-l-2 border-violet-100 hover:border-violet-400 pl-4 py-1 transition-colors duration-200">
      <h3 class="text-[#2D2B35] font-black text-base md:text-lg mb-2 mt-0">
        {q.question}
      </h3>
      <p class="text-zinc-600 text-sm md:text-base leading-relaxed m-0">
        {q.answer}
      </p>
    </div>
  ))}
</div>
