---
const today = new Date();
---
<footer class="mt-32 border-t border-black/5 bg-white/30 backdrop-blur-sm py-12 text-center">
  <div class="container mx-auto max-w-5xl px-4 flex flex-col items-center gap-4">
    <a href="/" class="text-xl font-black tracking-tighter flex items-center gap-2 text-zinc-400 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all">
      <img src="https://adhdos.app/assets/icon_ADHDOS.png" alt="Logo" class="w-6 h-6 rounded-md" />
      ADHD OS
    </a>
    <p class="text-zinc-400 text-sm font-medium">
      &copy; {today.getFullYear()} Simpfly. 保留所有权利。
    </p>
  </div>
</footer>
